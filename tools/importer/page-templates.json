          "name": "Smart Choice",
          "selector": "#SmartChoice",
          "style": "light",
          "blocks": ["cards-teaser"],
          "defaultContent": ["#SmartChoice div.cmp-title h2"]
        },
        {
          "id": "producer-banner",
          "name": "Producer Banner",
          "selector": "#main-content > div.aem-Grid > div.section.cmp-section--background-color-dark-blue:nth-of-type(6)",
          "style": "dark-blue",
          "blocks": [],
